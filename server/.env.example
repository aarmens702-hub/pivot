# Backend env vars. Copy to `server/.env` for local dev. Railway injects its
# own PORT in production.

# Port the Express server listens on. Defaults to 5174 if unset.
PORT=5174

# Allowed CORS origin in production. Leave blank in dev (wildcard). Set to the
# deployed Vercel URL once known, e.g. https://pivot.vercel.app
CORS_ORIGIN=

# Set to "production" to enable Helmet + rate limiting + CORS lockdown.
NODE_ENV=development
